root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

# Kotlin / Java
[*.{kt,kts,java}]
indent_size = 4
ktlint_standard_no-wildcard-imports = enabled

# Gradle (Groovy fallback), JSON, YAML, web
[*.{json,yml,yaml,js,jsx,ts,tsx,html,css,scss}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{proto}]
indent_size = 2

[Makefile]
indent_style = tab
